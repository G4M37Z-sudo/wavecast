<?xml version="1.0" encoding="utf-8"?>
<!--
  Android 12+ data extraction rules. We don't back up user data
  (no accounts, no PII); the only persisted state is the device
  name and server URL which are just configuration preferences.
-->
<data-extraction-rules>
    <cloud-backup>
        <exclude domain="sharedpref" path="." />
    </cloud-backup>
    <device-transfer>
        <exclude domain="sharedpref" path="." />
    </device-transfer>
</data-extraction-rules>
