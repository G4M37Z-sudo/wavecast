<?xml version="1.0" encoding="utf-8"?>
<!--
  Adaptive launcher icon. Two layers:
    - background: indigo→blue gradient (matches the brand mark on the web)
    - foreground: white circle (the brand mark's center dot)
  Android picks the right form (square, round, themed) automatically.
-->
<adaptive-icon xmlns:android="http://schemas.android.com/apk/res/android">
    <background android:drawable="@drawable/ic_launcher_background" />
    <foreground android:drawable="@drawable/ic_launcher_foreground" />
    <monochrome android:drawable="@drawable/ic_launcher_foreground" />
</adaptive-icon>
